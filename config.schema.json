{
  "pluginAlias": "XiaomiMiAirPurifier",
  "pluginType": "accessory",
  "singular": false,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "required": true,
        "default": "Air Purifier",
        "placeholder": "Air Purifier"
      },
      "address": {
        "title": "IP Address",
        "type": "string",
        "required": true,
        "format": "ipv4"
      },
      "token": {
        "title": "Token",
        "type": "string",
        "required": true,
        "pattern": "^\\w{32}$"
      },
      "model": {
        "title": "Model",
        "type": "string",
        "required": true,
        "enum": [
          "zhimi.airpurifier.2h",
          "zhimi.airpurifier.3",
          "zhimi.airpurifier.3h",
          "zhimi.airpurifier.4",
          "zhimi.airpurifier.pro"
        ]
      },
      "filterChangeThreshold": {
        "title": "Filter Change Warning Threshold",
        "type": "integer",
        "default": 10,
        "minimum": 0,
        "maximum": 100,
        "description": "Show <b>Change Filter</b> warning when Filter Life reaches or drops below this value."
      },
      "connectTimeoutMs": {
        "title": "Connect Timeout (ms)",
        "type": "integer",
        "default": 15000,
        "minimum": 100,
        "description": "Timeout for MIIO handshake/connect operations."
      },
      "operationTimeoutMs": {
        "title": "Operation Timeout (ms)",
        "type": "integer",
        "default": 15000,
        "minimum": 100,
        "description": "Timeout for read/write operations after connection."
      },
      "reconnectDelayMs": {
        "title": "Reconnect Delay (ms)",
        "type": "integer",
        "default": 15000,
        "minimum": 100,
        "description": "Base delay used by reconnect backoff policy."
      },
      "keepAliveIntervalMs": {
        "title": "Keep Alive Interval (ms)",
        "type": "integer",
        "default": 60000,
        "minimum": 1000,
        "description": "Background keep-alive poll interval."
      },
      "exposeFilterReplaceAlertSensor": {
        "title": "Expose Filter Replace Alert Sensor",
        "type": "boolean",
        "default": false,
        "description": "Adds an extra Contact Sensor service for filter replacement warning. Keep disabled to avoid duplicate warning tiles in Homebridge UI."
      }
    }
  },
  "layout": [
    {
      "key": "name"
    },
    {
      "key": "model"
    },
    {
      "type": "flex",
      "flex-flow": "row wrap",
      "items": [
        "address",
        "token"
      ]
    },
    {
      "type": "help",
      "helpvalue": "Please check the README for instruction about how to get a <em>token</em>."
    },
    {
      "type": "section",
      "title": "Sensors",
      "expandable": true,
      "expanded": true,
      "items": []
    },
    {
      "type": "section",
      "title": "Advanced options",
      "expandable": true,
      "expanded": false,
      "items": [
        {
          "key": "filterChangeThreshold"
        },
        {
          "key": "exposeFilterReplaceAlertSensor"
        },
        {
          "key": "connectTimeoutMs"
        },
        {
          "key": "operationTimeoutMs"
        },
        {
          "key": "reconnectDelayMs"
        },
        {
          "key": "keepAliveIntervalMs"
        }
      ]
    }
  ]
}
